# ITB.guru build-time configuration.
# Edit, then rebuild:  docker compose up -d --build   (or ./build.sh for a local dist/)

# Availability badge in the hero (and its date text)
SHOW_AVAILABILITY=true
AVAILABILITY_DATE="Q3 2026"

# "/ THE LAB" section (also removes the "Lab" nav link)
SHOW_LAB=true

# "/ WRITING" section (also removes the "Writing" nav link).
# NOTE: the post links point at the old WordPress URLs on itb.guru — set this
# to false at cutover unless the posts have been migrated (see DEPLOY.md).
SHOW_WRITING=true
